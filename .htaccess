RewriteEngine On

# Chặn truy cập trực tiếp vào thư mục app, config, core
RewriteRule ^(app|config|core)(/.*)?$ - [F,L]

# Nếu file hoặc thư mục tồn tại, cho phép truy cập
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Chuyển tất cả request về index.php
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]